# ─── Claude / Anthropic ───────────────────────────────────────────────────────
# Dapatkan API Key di: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─── Voyage AI (Embeddings) ───────────────────────────────────────────────────
# Dapatkan API Key di: https://dash.voyageai.com/
# Free tier: 50 juta token/bulan (voyage-3-lite)
VOYAGE_API_KEY=your-voyage-api-key-here

# ─── Pinecone (Vector Database) ───────────────────────────────────────────────
# Dapatkan API Key di: https://app.pinecone.io/
# Free tier: 1 index, 100k vectors
PINECONE_API_KEY=your-pinecone-api-key-here

# Nama index Pinecone (akan dibuat otomatis jika belum ada)
PINECONE_INDEX_NAME=prolms-knowledge-base

# ─── OPSIONAL ─────────────────────────────────────────────────────────────────
# Ubah port jika diperlukan (default: 8001)
# APP_PORT=8001
